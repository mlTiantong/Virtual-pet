<Window x:Class="DesktopPet.App.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopPet M1" Width="1160" Height="760"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="True"
        Loaded="PetWindow_Loaded"
        SourceInitialized="PetWindow_SourceInitialized"
        Closing="PetWindow_Closing">
  <Canvas x:Name="RootCanvas" Background="Transparent">
    <Canvas.Resources>
      <DropShadowEffect x:Key="PanelShadow" BlurRadius="34" ShadowDepth="10" Opacity="0.12" Color="#7D93C8" />
      <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="4" Opacity="0.055" Color="#7A8FC6" />

      <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F2F5FAFF" Offset="0" />
        <GradientStop Color="#EDF3FFFF" Offset="0.46" />
        <GradientStop Color="#F0ECFFFF" Offset="1" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="PrimaryBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF9BB9FF" Offset="0" />
        <GradientStop Color="#FF6E86E7" Offset="1" />
      </LinearGradientBrush>

      <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#7180A5" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
      </Style>

      <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#53689B" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
      </Style>

      <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="#F8FFFFFF" />
        <Setter Property="BorderBrush" Value="#DDE7FFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
      </Style>

      <Style x:Key="AnimeButton" TargetType="Button">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Margin" Value="0,4,0,4" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Foreground" Value="#42547B" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="#F4F7FFFF" />
        <Setter Property="BorderBrush" Value="#D6E2FBFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Chrome"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="12">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Chrome" Property="Background" Value="#FFFFF4F9" />
                  <Setter TargetName="Chrome" Property="BorderBrush" Value="#F4A3C5FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Chrome" Property="Background" Value="#FFE7F0FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.64" />
                  <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource AnimeButton}">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="BorderBrush" Value="#7A95EFFF" />
      </Style>

      <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource AnimeButton}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Background" Value="#EEF3FFFF" />
      </Style>

      <Style x:Key="StudyChoiceButton" TargetType="Button" BasedOn="{StaticResource AnimeButton}">
        <Setter Property="MinHeight" Value="68" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Background" Value="#F8FBFFFF" />
        <Setter Property="BorderBrush" Value="#C7DAF5FF" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Chrome"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="18">
                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Chrome" Property="Background" Value="#FFFFF8FC" />
                  <Setter TargetName="Chrome" Property="BorderBrush" Value="#EEA8CDFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Chrome" Property="Background" Value="#FFE9F2FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.64" />
                  <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="InputBox" TargetType="TextBox">
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Margin" Value="0,4,0,9" />
        <Setter Property="Foreground" Value="#34466F" />
        <Setter Property="Background" Value="#F8FFFFFF" />
        <Setter Property="BorderBrush" Value="#C9DAF2FF" />
        <Setter Property="FontSize" Value="16" />
      </Style>

      <Style x:Key="SoftProgress" TargetType="ProgressBar">
        <Setter Property="Height" Value="9" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="Foreground" Value="#7CB8F4" />
        <Setter Property="Background" Value="#E7ECF7" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ProgressBar">
              <Grid x:Name="TemplateRoot" ClipToBounds="True">
                <Border Background="{TemplateBinding Background}" CornerRadius="5" />
                <Border x:Name="PART_Track" CornerRadius="5" />
                <Grid x:Name="PART_Indicator" HorizontalAlignment="Left" ClipToBounds="True">
                  <Border Background="{TemplateBinding Foreground}" CornerRadius="5" />
                </Grid>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </Canvas.Resources>

    <Image x:Name="PetSprite"
           Width="390" Height="390"
           Canvas.Left="22" Canvas.Top="270"
           Stretch="Uniform"
           RenderOptions.BitmapScalingMode="HighQuality"
           SnapsToDevicePixels="True"
           MouseEnter="PetSprite_MouseEnter"
           MouseLeave="PetSprite_MouseLeave"
           MouseMove="PetSprite_MouseMove"
           MouseLeftButtonDown="PetSprite_MouseLeftButtonDown"
           MouseLeftButtonUp="PetSprite_MouseLeftButtonUp" />

    <Image x:Name="PetSpriteOverlay"
           Width="390" Height="390"
           Canvas.Left="22" Canvas.Top="270"
           Stretch="Uniform"
           RenderOptions.BitmapScalingMode="HighQuality"
           SnapsToDevicePixels="True"
           IsHitTestVisible="False"
           Visibility="Collapsed" />

    <Canvas x:Name="PropLayer" Canvas.Left="0" Canvas.Top="0" Width="1160" Height="760" IsHitTestVisible="False" />

    <Border x:Name="BubbleBorder"
            Canvas.Left="72" Canvas.Top="88"
            MaxWidth="360"
            Padding="22,14"
            Background="#FAFFFFFF"
            BorderBrush="#D5DDF6FF"
            BorderThickness="1"
            CornerRadius="14"
            Visibility="Collapsed"
            MouseEnter="HudOrBubble_MouseEnter"
            MouseLeave="HudOrBubble_MouseLeave"
            Effect="{StaticResource CardShadow}">
      <TextBlock x:Name="BubbleText" TextWrapping="Wrap" Foreground="#435579" FontSize="16" FontWeight="SemiBold" />
    </Border>

    <Border x:Name="HudPanel"
            Canvas.Left="430" Canvas.Top="42"
            Width="670" Height="667"
            Padding="22"
            Background="{StaticResource ShellBrush}"
            BorderBrush="#F7FFFFFF"
            BorderThickness="1"
            CornerRadius="28"
            Visibility="Collapsed"
            MouseEnter="HudOrBubble_MouseEnter"
            MouseLeave="HudOrBubble_MouseLeave"
            MouseMove="HudPanel_MouseMove"
            Effect="{StaticResource PanelShadow}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="38" />
          <RowDefinition Height="104" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="360" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="248" />
        </Grid.ColumnDefinitions>

        <Canvas Grid.RowSpan="3" Grid.ColumnSpan="3" IsHitTestVisible="False" Opacity="0.88">
          <Ellipse Canvas.Left="-40" Canvas.Top="-54" Width="285" Height="170" Fill="#DCE9FFFF" Opacity="0.28" />
          <Ellipse Canvas.Left="428" Canvas.Top="8" Width="225" Height="190" Fill="#F5F1FFFF" Opacity="0.42" />
          <TextBlock Text="❄" Canvas.Left="255" Canvas.Top="10" Foreground="#DDE6FFFF" FontSize="46" Opacity="0.52" />
          <TextBlock Text="❄" Canvas.Left="276" Canvas.Top="35" Foreground="#CFDCFFFF" FontSize="23" Opacity="0.38" />
          <TextBlock Text="❄" Canvas.Left="566" Canvas.Top="418" Foreground="#C9D8FFFF" FontSize="58" Opacity="0.36" />
          <TextBlock Text="✧" Canvas.Left="21" Canvas.Top="25" Foreground="#B9C9F7" FontSize="17" Opacity="0.8" />
          <TextBlock Text="✦" Canvas.Left="342" Canvas.Top="32" Foreground="#FFFFFF" FontSize="12" Opacity="0.95" />
          <TextBlock Text="✦" Canvas.Left="606" Canvas.Top="132" Foreground="#FFFFFF" FontSize="19" Opacity="0.76" />
          <TextBlock Text="✧" Canvas.Left="638" Canvas.Top="494" Foreground="#AFC1F4" FontSize="17" Opacity="0.78" />
          <TextBlock Text="✦" Canvas.Left="624" Canvas.Top="518" Foreground="#B5C5F7" FontSize="14" Opacity="0.82" />
          <Line X1="360" Y1="35" X2="508" Y2="35" Stroke="#FFFFFF" StrokeThickness="1" Opacity="0.62" />
          <Ellipse Canvas.Left="426" Canvas.Top="31" Width="6" Height="6" Fill="#FFFFFF" Opacity="0.9" />
          <Line X1="37" Y1="148" X2="115" Y2="148" Stroke="#EEF3FFFF" StrokeThickness="1" Opacity="0.58" />
          <Line X1="292" Y1="597" X2="390" Y2="597" Stroke="#EEF3FFFF" StrokeThickness="1" Opacity="0.5" />
        </Canvas>

        <Canvas x:Name="HudSnowLayer"
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                IsHitTestVisible="False"
                Opacity="0.54"
                Panel.ZIndex="1" />

        <Canvas x:Name="HudLinkLayer"
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                IsHitTestVisible="False"
                Opacity="0.64"
                Panel.ZIndex="20" />

        <Grid Grid.Row="0" Grid.ColumnSpan="3">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="✦" Foreground="#A9BDF7" FontSize="18" Margin="0,0,9,0" />
            <TextBlock Text="M1 LIVE TERMINAL" Foreground="#657DC8" FontSize="16" FontWeight="Black" />
          </StackPanel>
          <Button Grid.Column="1" Style="{StaticResource AnimeButton}" Width="42" Height="32" MinHeight="32" Padding="0" Content="－" Click="HudCloseButton_Click" Margin="0,0,10,0" />
          <Button Grid.Column="2" Style="{StaticResource AnimeButton}" Width="42" Height="32" MinHeight="32" Padding="0" Content="×" Click="HudCloseButton_Click" />
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GlassCard}" Padding="18" Margin="0,4,0,14">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="64" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <Border Width="58" Height="58" CornerRadius="16" Background="#EEF4FFFF" BorderBrush="#C7D7F8FF" BorderThickness="1">
              <Viewbox Width="42" Height="42" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas Width="42" Height="42">
                  <Ellipse Canvas.Left="3" Canvas.Top="3" Width="36" Height="36" Fill="#F8FBFFFF" Stroke="#D7E4FFFF" StrokeThickness="1.4" />
                  <Path Data="M11,12 C15,9.6 18.7,9.6 21,12 L21,31 C18.1,28.8 14.5,28.8 11,31 Z"
                        Fill="#EAF1FFFF"
                        Stroke="#6A85E2"
                        StrokeThickness="2.1"
                        StrokeLineJoin="Round" />
                  <Path Data="M21,12 C23.3,9.6 27,9.6 31,12 L31,31 C27.5,28.8 23.9,28.8 21,31 Z"
                        Fill="#F3F7FFFF"
                        Stroke="#6A85E2"
                        StrokeThickness="2.1"
                        StrokeLineJoin="Round" />
                  <Line X1="21" Y1="12" X2="21" Y2="31" Stroke="#6A85E2" StrokeThickness="1.4" />
                  <Path Data="M14,16 C15.5,15.4 17,15.4 18.5,16 M14,20 C15.4,19.5 17,19.5 18.5,20 M23.8,16 C25.4,15.4 27,15.4 28.5,16 M23.8,20 C25.2,19.5 27,19.5 28.5,20"
                        Stroke="#9BAEF0"
                        StrokeThickness="1.2"
                        StrokeStartLineCap="Round"
                        Fill="Transparent" />
                  <Path Data="M32.5,7.8 L34.1,11.3 L37.8,12.9 L34.1,14.4 L32.5,18 L31,14.4 L27.3,12.9 L31,11.3 Z"
                        Fill="#B8C8FFFF"
                        Opacity="0.9" />
                  <Ellipse Canvas.Left="8" Canvas.Top="8" Width="3.5" Height="3.5" Fill="#FFFFFF" Opacity="0.95" />
                </Canvas>
              </Viewbox>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock x:Name="ModeText" Text="空闲" Foreground="#334576" FontSize="21" FontWeight="Black" />
              <TextBlock x:Name="ModeDetailText" Text="◷ 剩余时间 00:42:15" Foreground="#6174A8" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="✧" Foreground="#9AACF0" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GlassCard}" Padding="16" Margin="0,0,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Background="Transparent" BorderBrush="{x:Null}" BorderThickness="0" Padding="0" Margin="0,0,0,12">
            <UniformGrid Columns="4">
              <Button x:Name="HomeNavButton" Style="{StaticResource NavButton}" Content="空闲" Tag="Home" Click="NavButton_Click" />
              <Button x:Name="StudyNavButton" Style="{StaticResource NavButton}" Content="学习" Tag="Study" Click="NavButton_Click" />
              <Button x:Name="ChatNavButton" Style="{StaticResource NavButton}" Content="照料" Tag="Care" Click="NavButton_Click" />
              <Button x:Name="SettingsNavButton" Style="{StaticResource NavButton}" Content="设置" Tag="Settings" Click="NavButton_Click" />
            </UniformGrid>
          </Border>

          <Grid Grid.Row="1">
            <Grid x:Name="HomePage">
              <StackPanel>
                <TextBlock Text="当前节奏" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
                <UniformGrid Columns="3" Margin="0,0,0,16">
                  <Border Style="{StaticResource GlassCard}" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="待机动作" Style="{StaticResource MutedText}" />
                      <TextBlock x:Name="NextIdleText" Text="30秒后" Foreground="#D95D95" FontWeight="Black" FontSize="15" />
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource GlassCard}" Padding="12" Margin="0,0,8,0">
                    <StackPanel>
                      <TextBlock Text="互动" Style="{StaticResource MutedText}" />
                      <TextBlock x:Name="TodayInteractionsText" Text="0次" Foreground="#517CE0" FontWeight="Black" FontSize="15" />
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource GlassCard}" Padding="12" Margin="0">
                    <StackPanel>
                      <TextBlock Text="陪伴" Style="{StaticResource MutedText}" />
                      <TextBlock x:Name="CompanionText" Text="00:00" Foreground="#2D927B" FontWeight="Black" FontSize="15" />
                    </StackPanel>
                  </Border>
                </UniformGrid>

                <TextBlock Text="聊天" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="82" />
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="ChatBox" Style="{StaticResource InputBox}" Margin="0,0,8,0" ToolTip="输入一句话" />
                  <Button x:Name="ChatSendButton" Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="发送" Click="ChatSendButton_Click" Margin="0" />
                </Grid>
                <UniformGrid Columns="2">
                  <Button x:Name="RandomIdleButton" Style="{StaticResource AnimeButton}" Content="随机待机" Click="RandomIdleButton_Click" Margin="0,4,8,4" />
                  <Button x:Name="SleepButton" Style="{StaticResource AnimeButton}" Content="去睡觉" Click="SleepButton_Click" Margin="8,4,0,4" />
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,16,0,0">
                  <Border Style="{StaticResource GlassCard}" Padding="14" Margin="0,0,8,0" MinHeight="96">
                    <StackPanel>
                      <TextBlock Text="状态提醒" Foreground="#53689B" FontSize="15" FontWeight="Black" />
                      <TextBlock Text="空闲时会自动挑选待机动作。" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource GlassCard}" Padding="14" Margin="8,0,0,0" MinHeight="96">
                    <StackPanel>
                      <TextBlock Text="陪伴记录" Foreground="#53689B" FontSize="15" FontWeight="Black" />
                      <TextBlock Text="互动和学习会同步更新右侧状态。" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                </UniformGrid>

                <Border CornerRadius="16" Background="#F8FFFFFF" BorderBrush="#E0E9F8FF" BorderThickness="1" Padding="15" Margin="0,14,0,0">
                  <TextBlock Text="✥ 点击桌宠、聊天、投喂或拖拽都会刷新当前节奏。" Foreground="#B88963" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </Grid>

            <Grid x:Name="CarePage" Visibility="Collapsed">
              <StackPanel>
                <TextBlock Text="照料" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
                <Button Style="{StaticResource PrimaryButton}" Content="摸头" Click="PatButton_Click" />
                <TextBlock Text="投喂" Style="{StaticResource LabelText}" Margin="0,18,0,8" />
                <UniformGrid Columns="3">
                  <Button x:Name="SnackButton" Style="{StaticResource AnimeButton}" Content="点心" Click="SnackButton_Click" Margin="0,4,8,4" />
                  <Button x:Name="MealButton" Style="{StaticResource AnimeButton}" Content="正餐" Click="MealButton_Click" Margin="8,4" />
                  <Button x:Name="TeaButton" Style="{StaticResource AnimeButton}" Content="热茶" Click="TeaButton_Click" Margin="8,4,0,4" />
                </UniformGrid>
                <Border Style="{StaticResource GlassCard}" Margin="0,18,0,0">
                  <TextBlock Text="进食中不能开始学习、睡觉或切换随机动作；聊天时可以投喂。" Style="{StaticResource MutedText}" />
                </Border>
              </StackPanel>
            </Grid>

            <Grid x:Name="StudyPage" Visibility="Collapsed">
              <Border Padding="0" Background="Transparent">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="学习内容" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
                    <UniformGrid Columns="2">
                      <Button x:Name="ReadingKindButton" Style="{StaticResource StudyChoiceButton}" Click="ReadingKindButton_Click" Margin="0,0,10,0" Height="68">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Width="34" Height="34" CornerRadius="12" Background="#EAF2FFFF" BorderBrush="#D5E4FFFF" BorderThickness="1">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <Grid Width="24" Height="24">
                                <Path Data="M5,4 L11.5,3 L11.5,20 L5,21 Z M12.5,3 L19,4 L19,21 L12.5,20 Z"
                                      Fill="#DFEAFFFF"
                                      Stroke="#5E7FDB"
                                      StrokeThickness="1.7"
                                      StrokeLineJoin="Round" />
                                <Line X1="12" Y1="3.5" X2="12" Y2="20.2" Stroke="#5E7FDB" StrokeThickness="1.2" />
                              </Grid>
                            </Viewbox>
                          </Border>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0,0,0">
                            <TextBlock Text="读书" FontSize="17" FontWeight="Black" />
                            <TextBlock Text="Reading focus" FontSize="11" FontWeight="Bold" Opacity="0.72" Margin="0,2,0,0" />
                          </StackPanel>
                        </Grid>
                      </Button>
                      <Button x:Name="PaintingKindButton" Style="{StaticResource StudyChoiceButton}" Click="PaintingKindButton_Click" Margin="10,0,0,0" Height="68">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Border Width="34" Height="34" CornerRadius="12" Background="#FFF2F7FF" BorderBrush="#FFD5E9FF" BorderThickness="1">
                            <Viewbox Width="21" Height="21" HorizontalAlignment="Center" VerticalAlignment="Center">
                              <Grid Width="24" Height="24">
                                <Ellipse Canvas.Left="0" Canvas.Top="0" Width="20" Height="20" Stroke="#C86FA2" StrokeThickness="1.8" Fill="#FFF6FBFF" />
                                <Ellipse Width="4" Height="4" Fill="#E58AB8" Margin="6,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <Ellipse Width="4" Height="4" Fill="#9CB5F7" Margin="13,6,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <Ellipse Width="4" Height="4" Fill="#F0C06E" Margin="9,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <Path Data="M17,16 L23,22" Stroke="#C86FA2" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                              </Grid>
                            </Viewbox>
                          </Border>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0,0,0">
                            <TextBlock Text="画画" FontSize="17" FontWeight="Black" />
                            <TextBlock Text="Painting time" FontSize="11" FontWeight="Bold" Opacity="0.72" Margin="0,2,0,0" />
                          </StackPanel>
                        </Grid>
                      </Button>
                    </UniformGrid>
                  </StackPanel>

                  <StackPanel Grid.Row="1">
                    <TextBlock Text="选择时长" Style="{StaticResource LabelText}" Margin="0,0,0,8" />
                    <UniformGrid Columns="3" Margin="0,0,0,16">
