                          <TextBlock Text="25分钟" FontSize="20" FontWeight="Black" HorizontalAlignment="Center" />
                          <TextBlock Text="专注" FontSize="16" Foreground="#7F90B8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,7,0,0" />
                        </StackPanel>
                      </Button>
                      <Button x:Name="Study60Button" Style="{StaticResource PrimaryButton}" Click="Study60Button_Click" Margin="10,3" Height="86">
